{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Twenty App",
  "version": "0.1.1",
  "identifier": "com.rubixstudios.twenty",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:5174",
    "beforeDevCommand": "pnpm run dev:ui",
    "beforeBuildCommand": "pnpm run build:ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Twenty",
        "label": "main",
        "width": 1000,
        "height": 600,
        "minWidth": 1000,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "visible": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "publisher": "Rubix Studios",
    "windows": {
      "nsis": {
        "installMode": "both",
        "compression": "lzma"
      }
    },
    "macOS": {
      "signingIdentity": null
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDcxOTAxRjkxREEwMDM2RDYKUldUV05nRGFrUitRY1orUG54VWZVUlIrQm42dFNpV2VCL0wwWUwrMTFDM1FBOGhBZnNiSzFsY2QK",
      "endpoints": [
        "https://github.com/rubix-studios-pty-ltd/twenty-app/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
